---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DownloadLinks, GITHUB_ISSUES } from '@/lib/constants';
---

<BaseLayout title="Download Target Mate" description="Download Target Mate for macOS, Windows, iOS, and Android." canonicalUrl="/downloads">
  <div class="container py-24">
    <div class="flex flex-col items-center text-center mb-12">
      <h1 class="text-4xl font-bold mb-4 text-center">Download <img src="/text_logo.svg" alt="Target Mate" class="inline pb-1 h-[40px]" /></h1>
      <p class="text-muted-foreground max-w-[600px]">
        Choose your platform and start managing your goals more efficiently today!
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6 max-w-[800px] mx-auto">
      <!-- macOS -->
      <div class="rounded-xl border bg-card text-card-foreground shadow flex flex-col">
        <div class="flex flex-col space-y-1.5 p-6 flex-1">
          <h3 class="font-semibold leading-none tracking-tight flex items-center gap-2 text-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 560.35 560.035" fill="currentColor" stroke="currentColor" class="h-6 w-6"><path d="M380.844 297.529c.787 84.752 74.349 112.955 75.164 113.314-.622 1.988-11.754 40.191-38.756 79.652-23.343 34.117-47.568 68.107-85.731 68.811-37.499.691-49.557-22.236-92.429-22.236-42.859 0-56.256 21.533-91.753 22.928-36.837 1.395-64.889-36.891-88.424-70.883-48.093-69.53-84.846-196.475-35.496-282.165 24.516-42.554 68.328-69.501 115.882-70.192 36.173-.69 70.315 24.336 92.429 24.336 22.1 0 63.59-30.096 107.208-25.676 18.26.76 69.517 7.376 102.429 55.552-2.652 1.644-61.159 35.704-60.523 106.559M310.369 89.418C329.926 65.745 343.089 32.79 339.498 0 311.308 1.133 277.22 18.785 257 42.445c-18.121 20.952-33.991 54.487-29.709 86.628 31.421 2.431 63.52-15.967 83.078-39.655"/></svg>
            macOS
          </h3>
          <p class="text-sm text-muted-foreground text-base mt-2">
            For Apple Silicon and Intel Macs
          </p>
          <div class="mt-4 text-sm text-muted-foreground">
            <p>Universal binary supporting both Apple Silicon and Intel processors</p>
            <p class="mt-2">Optimized for macOS Sonoma and above</p>
          </div>
        </div>
        <div class="p-6 pt-0 mt-auto space-y-3">
          <a
            href={DownloadLinks.MAC_STORE}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground w-full gap-2 py-6 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor" stroke="currentColor" class="h-5 w-5"><path d="M255.9,116.5l9.4-16.2c5.8-10.1,18.7-13.5,28.8-7.8c10.1,5.8,13.5,18.7,7.7,28.8l-90.3,156.4h65.3 c21.2,0,33,24.9,23.8,42.1H109.2c-11.7,0-21.1-9.4-21.1-21.1c0-11.7,9.4-21.1,21.1-21.1h53.7l68.7-119.1l-21.5-37.3 c-5.8-10.1-2.4-22.9,7.7-28.8c10.1-5.8,22.9-2.4,28.8,7.8L255.9,116.5z M174.7,341.6l-20.2,35.1c-5.8,10.1-18.7,13.5-28.8,7.7 c-10.1-5.8-13.5-18.7-7.7-28.8l15.1-26C149.9,324.3,163.7,328.4,174.7,341.6z M349,277.9h54.8c11.7,0,21.1,9.4,21.1,21.1 s-9.4,21.1-21.1,21.1h-30.5l20.5,35.6c5.8,10.1,2.4,22.9-7.8,28.8c-10.1,5.8-22.9,2.4-28.8-7.7c-34.6-60-60.6-104.9-77.8-134.8 c-17.7-30.5-5-61,7.4-71.3C300.8,194.3,321.4,230.1,349,277.9z M256,0C114.6,0,0,114.6,0,256s114.6,256,256,256 c141.4,0,256-114.6,256-256S397.4,0,256,0z M479,256c0,122.5-99.2,223-223,223c-122.5,0-223-99.2-223-223c0-122.5,99.2-223,223-223 C378.5,33,479,132.2,479,256z"/></svg>
            Download from App Store
          </a>
          <a
            href={DownloadLinks.MAC_DIRECT}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 w-full gap-2 py-6 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Direct Download (.dmg)
          </a>
        </div>
      </div>

      <!-- Android -->
      <div class="rounded-xl border bg-card text-card-foreground shadow flex flex-col">
        <div class="flex flex-col space-y-1.5 p-6 flex-1">
          <h3 class="font-semibold leading-none tracking-tight flex items-center gap-2 text-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M380.91,199l42.47-73.57a8.63,8.63,0,0,0-3.12-11.76,8.52,8.52,0,0,0-11.71,3.12l-43,74.52c-32.83-15-69.78-23.35-109.52-23.35s-76.69,8.36-109.52,23.35l-43-74.52a8.6,8.6,0,1,0-14.88,8.64L131,199C57.8,238.64,8.19,312.77,0,399.55H512C503.81,312.77,454.2,238.64,380.91,199ZM138.45,327.65a21.46,21.46,0,1,1,21.46-21.46A21.47,21.47,0,0,1,138.45,327.65Zm235,0A21.46,21.46,0,1,1,395,306.19,21.47,21.47,0,0,1,373.49,327.65Z"/></svg>
            Android
          </h3>
          <p class="text-sm text-muted-foreground text-base mt-2">
            Compatible with Android 8.0 and later
          </p>
          <div class="mt-4 text-sm text-muted-foreground">
            <p>Enjoy seamless background synchronization and real-time notifications.</p>
          </div>
        </div>
        <div class="p-6 pt-0 mt-auto space-y-3">
          <a
            href={DownloadLinks.ANDROID_STORE}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground w-full gap-2 py-6 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M9.3,5.52a7,7,0,0,1,2,.76L32.52,18l-5.87,6L7.68,5.9A2.46,2.46,0,0,1,9.3,5.52ZM7.68,5.9l19,18.1L7.7,42.07c-.7-.56-1.07-1.69-1.07-3.36V9.29c0-1.67.36-2.82,1-3.38ZM32.52,18l7,3.87c2.49,1.38,2.49,2.84,0,4.22l-7,3.87-5.87-6,5.87-6Zm0,12L11.34,41.72c-1.16.64-2.72,1.19-3.64.35L26.65,24Z"/></svg>
            Get it on Google Play
          </a>
          <a
            href={DownloadLinks.ANDROID_DIRECT}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 w-full gap-2 py-6 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Direct Download (.apk)
          </a>
        </div>
      </div>

      <!-- Windows -->
      <div class="rounded-xl border bg-card text-card-foreground shadow flex flex-col">
        <div class="flex flex-col space-y-1.5 p-6 flex-1">
          <h3 class="font-semibold leading-none tracking-tight flex items-center gap-2 text-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 498.57 498.57" fill="currentColor" stroke="currentColor" class="h-6 w-6"><path d="M165.265,53.107L21.689,81.753v132.531l143.575-2.416V53.107 M431.297,245.583l-233.18-3.991 v164.822l233.18,46.571V245.583 M165.265,241.097l-143.575-2.438v132.509l143.575,28.668V241.097 M431.297,0l-233.18,46.528 v164.822l233.18-3.969V0"/></svg>
            Windows
          </h3>
          <p class="text-sm text-muted-foreground text-base mt-2">
            Windows 10 and above
          </p>
          <div class="mt-4 text-sm text-muted-foreground">
            <p>64-bit installer with automatic updates</p>
            <p class="mt-2">Windows 10/11 native features support</p>
          </div>
        </div>
        <div class="p-6 pt-0 mt-auto">
          <a
            href={DownloadLinks.WINDOWS_DIRECT}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 w-full gap-2 py-6 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Direct Download (.exe)
          </a>
        </div>
      </div>

      <!-- iOS -->
      <div class="rounded-xl border bg-card text-card-foreground shadow flex flex-col">
        <div class="flex flex-col space-y-1.5 p-6 flex-1">
          <h3 class="font-semibold leading-none tracking-tight flex items-center gap-2 text-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 560.35 560.035" fill="currentColor" stroke="currentColor" class="h-6 w-6"><path d="M380.844 297.529c.787 84.752 74.349 112.955 75.164 113.314-.622 1.988-11.754 40.191-38.756 79.652-23.343 34.117-47.568 68.107-85.731 68.811-37.499.691-49.557-22.236-92.429-22.236-42.859 0-56.256 21.533-91.753 22.928-36.837 1.395-64.889-36.891-88.424-70.883-48.093-69.53-84.846-196.475-35.496-282.165 24.516-42.554 68.328-69.501 115.882-70.192 36.173-.69 70.315 24.336 92.429 24.336 22.1 0 63.59-30.096 107.208-25.676 18.26.76 69.517 7.376 102.429 55.552-2.652 1.644-61.159 35.704-60.523 106.559M310.369 89.418C329.926 65.745 343.089 32.79 339.498 0 311.308 1.133 277.22 18.785 257 42.445c-18.121 20.952-33.991 54.487-29.709 86.628 31.421 2.431 63.52-15.967 83.078-39.655"/></svg>
            iOS
          </h3>
          <p class="text-sm text-muted-foreground text-base mt-2">
            iOS 14.0 and above
          </p>
          <div class="mt-4 text-sm text-muted-foreground">
            <p>Compatible with all iPhones and iPads, offering a seamless experience across devices.</p>
          </div>
        </div>
        <div class="p-6 pt-0 mt-auto">
          <a
            href={DownloadLinks.IOS_STORE}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 w-full gap-2 py-6 text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor" stroke="currentColor" class="h-5 w-5"><path d="M255.9,116.5l9.4-16.2c5.8-10.1,18.7-13.5,28.8-7.8c10.1,5.8,13.5,18.7,7.7,28.8l-90.3,156.4h65.3 c21.2,0,33,24.9,23.8,42.1H109.2c-11.7,0-21.1-9.4-21.1-21.1c0-11.7,9.4-21.1,21.1-21.1h53.7l68.7-119.1l-21.5-37.3 c-5.8-10.1-2.4-22.9,7.7-28.8c10.1-5.8,22.9-2.4,28.8,7.8L255.9,116.5z M174.7,341.6l-20.2,35.1c-5.8,10.1-18.7,13.5-28.8,7.7 c-10.1-5.8-13.5-18.7-7.7-28.8l15.1-26C149.9,324.3,163.7,328.4,174.7,341.6z M349,277.9h54.8c11.7,0,21.1,9.4,21.1,21.1 s-9.4,21.1-21.1,21.1h-30.5l20.5,35.6c5.8,10.1,2.4,22.9-7.8,28.8c-10.1,5.8-22.9,2.4-28.8-7.7c-34.6-60-60.6-104.9-77.8-134.8 c-17.7-30.5-5-61,7.4-71.3C300.8,194.3,321.4,230.1,349,277.9z M256,0C114.6,0,0,114.6,0,256s114.6,256,256,256 c141.4,0,256-114.6,256-256S397.4,0,256,0z M479,256c0,122.5-99.2,223-223,223c-122.5,0-223-99.2-223-223c0-122.5,99.2-223,223-223 C378.5,33,479,132.2,479,256z"/></svg>
            Download on App Store
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-center text-center mt-12">
      <h2 class="text-2xl font-bold mb-4">Report Issues</h2>
      <p class="text-muted-foreground max-w-[600px] mb-4">
        If you encounter any issues while downloading or using the app, please let us know!
      </p>
      <a
        href={GITHUB_ISSUES}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring h-9 px-4 py-2 border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground"
      >
        Report an Issue
      </a>
    </div>
  </div>
</BaseLayout>
