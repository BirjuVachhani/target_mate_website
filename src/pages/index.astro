---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero } from '../components/react/Hero';
import { FAQ } from '../components/react/FAQ';
import { Testimonials } from '../components/react/Testimonials';
import { FEATURES, GITHUB_ISSUES, APP_NAME, TOGGL } from '../lib/constants';
---

<BaseLayout
  title="Target Mate - Toggl Track Companion App for Time Management"
  description="A companion app for Toggl Track to manage your working hours and achieve your monthly goals. Available for Windows, macOS, iOS, and Android."
>
  <Fragment slot="head">
    {/* Preload hero screenshots */}
    <link rel="preload" as="image" href="/screenshots/screenshot_1.png" />
    <link rel="preload" as="image" href="/screenshots/iphone_14_frame.png" />

    {/* JSON-LD: SoftwareApplication */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Target Mate",
      "description": "A companion app for Toggl Track to manage your working hours and achieve your monthly goals.",
      "applicationCategory": "ProductivityApplication",
      "operatingSystem": "Windows, macOS, iOS, Android",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Person",
        "name": "Birju Vachhani",
        "url": "https://birju.dev"
      },
      "url": "https://targetmate.birju.dev",
      "downloadUrl": "https://targetmate.birju.dev/downloads"
    })} />

    {/* JSON-LD: FAQPage */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I get my Toggl Track API key?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Log in to your Toggl Track account, navigate to your Profile settings at track.toggl.com/profile, scroll down to find the API Token section, and click to reveal your API token."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a Toggl Track account to use Target Mate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Target Mate is a companion app that works exclusively with Toggl Track. You'll need an active Toggl Track account to use our features for tracking and managing your working hours."
          }
        },
        {
          "@type": "Question",
          "name": "How does Target Mate calculate daily targets?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Target Mate takes into account your monthly hour limit, remaining working days, and already tracked hours to calculate optimal daily targets. It automatically adjusts these targets based on your actual working patterns and time tracked."
          }
        },
        {
          "@type": "Question",
          "name": "Is my Toggl Track data secure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely! Target Mate uses secure authentication methods to access your Toggl Track data. We don't store any of your time entries - all data stays on your local machine and is only used for calculations and displaying statistics."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use Target Mate offline?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Target Mate requires an internet connection to sync with Toggl Track. However, once synced, you can view your statistics and targets offline. The next sync will occur automatically when you're back online."
          }
        },
        {
          "@type": "Question",
          "name": "How often does Target Mate sync with Toggl Track?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "By default, Target Mate syncs every 5 minutes, but you can customize this interval in the settings. You can also trigger a manual sync whenever needed."
          }
        }
      ]
    })} />
  </Fragment>

  {/* Hero Section - React island (client:load for above-the-fold) */}
  <Hero client:load />

  {/* Features Section - Static Astro */}
  <section class="py-16 md:py-24" id="features">
    <div class="container">
      <div class="flex flex-col items-center justify-center space-y-4 text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tighter sm:text-5xl max-w-[800px]">
          Features that make a difference
        </h2>
        <p class="max-w-[600px] text-gray-500 md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed dark:text-gray-400">
          Discover why our app is the perfect solution for your needs
        </p>
      </div>
      <div class="space-y-24">
        {FEATURES.map((feature, index) => (
          <div class:list={["flex flex-col gap-12", index % 2 === 0 ? "lg:flex-row" : "lg:flex-row-reverse"]}>
            <div class="lg:w-1/2 space-y-4">
              <div class="inline-block rounded-lg bg-gray-100 p-3 dark:bg-gray-800">
                {feature.icon === "Goal" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><path d="M12 13V2l8 4-8 4"/><path d="M20.55 10.23A9 9 0 1 1 8 4.94"/><path d="M8 10a5 5 0 1 0 8.9 2.02"/></svg>
                )}
                {feature.icon === "Calendar" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                )}
                {feature.icon === "PersonStanding" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><circle cx="12" cy="5" r="1"/><path d="m9 20 3-6 3 6"/><path d="m6 8 6 2 6-2"/><path d="M12 10v4"/></svg>
                )}
                {feature.icon === "Filter" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                )}
                {feature.icon === "Palette" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
                )}
                {feature.icon === "Bell" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                )}
                {feature.icon === "Shield" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-primary"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
                )}
              </div>
              <h3 class="text-2xl font-bold">{feature.title}</h3>
              <p class="text-muted-foreground max-w-[500px]">
                {feature.description}
              </p>
            </div>
            <div class="lg:w-1/2 flex justify-center lg:justify-end">
              <div class="rounded-xl border bg-card text-card-foreground shadow w-full max-w-[600px] overflow-hidden">
                <div class="p-0">
                  <div class="aspect-video bg-gradient-to-br from-gray-900 to-gray-800 rounded-lg flex items-center justify-center">
                    <img
                      src={feature.image}
                      alt={feature.title}
                      class="rounded-lg object-cover w-full h-full"
                      loading="lazy"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Testimonials - React island (client:idle for below-the-fold) */}
  <Testimonials client:idle />

  {/* FAQ - React island (client:idle for below-the-fold) */}
  <FAQ client:idle />

  {/* Contact Section - Static Astro */}
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="flex flex-col items-center justify-center space-y-4 text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tighter sm:text-5xl max-w-[800px]">
          Get in Touch
        </h2>
        <p class="max-w-[600px] text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed">
          Have questions or feedback? We'd love to hear from you.
        </p>
      </div>

      <div class="rounded-xl border bg-card text-card-foreground shadow max-w-2xl mx-auto">
        <div class="p-6">
          <div class="grid gap-6">
            <div class="space-y-4">
              <h3 class="text-lg font-semibold">Contact Options</h3>
              <p class="text-muted-foreground">
                Whether you need help with setup, have feature requests, or just want to share your thoughts, feel free to reach out.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="mailto:brvachhani@gmail.com"
                class="flex-1 gap-2 h-auto py-6 inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 px-4"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <div class="text-left">
                  <div class="font-semibold">Email Us</div>
                  <div class="text-sm">For general inquiries</div>
                </div>
              </a>

              <a
                href={GITHUB_ISSUES}
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 gap-2 h-auto py-6 inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground px-4"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                <div class="text-left">
                  <div class="font-semibold">GitHub Issues</div>
                  <div class="text-sm text-muted-foreground">For bug reports & features</div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Disclaimer Section - Static Astro */}
  <section class="py-16">
    <div class="container">
      <div class="rounded-xl border border-muted bg-muted/50 text-card-foreground shadow">
        <div class="p-6">
          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-muted-foreground flex-shrink-0 mt-1"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            <div class="space-y-2">
              <h3 class="font-semibold text-lg">Important Note</h3>
              <p class="text-muted-foreground">
                Target Mate is not an independent time tracking application. It works exclusively as a companion app for <a href={TOGGL} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Toggl Track</a> to help you manage and visualize your working hours goals. You must use Toggl Track to record your time - Target Mate helps you stay on track with your daily and monthly targets while maintaining your preferred work-life balance.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
